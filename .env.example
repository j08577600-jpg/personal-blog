# Generate a strong secret with:
# openssl rand -base64 32
NEXTAUTH_SECRET=

# For production domain, use:
# https://blog.chenjilan.com
# For local development, temporarily use http://localhost:8080
NEXTAUTH_URL=https://blog.chenjilan.com

# GitHub OAuth
GITHUB_ID=
GITHUB_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth / Entra ID
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# 作者白名单：逗号分隔的授权邮箱，统一适用于 GitHub / Google / Microsoft
# 不配置或留空则不启用白名单（所有已登录用户可访问 dashboard）
ALLOWED_AUTHOR_EMAILS=
